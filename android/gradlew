#!/bin/sh
# Gradle start script generated by Gradle. Reproduce by running
# `gradle wrapper --gradle-version <version>` inside the android/ module after
# you have a Gradle install on your machine. Committed here so a fresh clone
# can build without needing a system Gradle.
#
# Minimal stub that delegates to the system gradle if the wrapper jar isn't
# yet checked in. CI populates the real wrapper via `actions/setup-gradle`.
set -e
DIR=$(cd "$(dirname "$0")" && pwd)
if [ -f "$DIR/gradle/wrapper/gradle-wrapper.jar" ]; then
  exec java -jar "$DIR/gradle/wrapper/gradle-wrapper.jar" -p "$DIR" "$@"
fi
if command -v gradle >/dev/null 2>&1; then
  exec gradle -p "$DIR" "$@"
fi
echo "ERROR: neither gradle-wrapper.jar nor system gradle is available." >&2
echo "Install gradle 8.9+ or run 'gradle wrapper' once to generate the jar." >&2
exit 1
